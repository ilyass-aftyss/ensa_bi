# ===========================================================================
# ENSA Kénitra — BI Architecture — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS COMMITTER .env dans git
# ===========================================================================

# --- Base de données (Railway PostgreSQL) ---
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/ensa_bi

# --- Sécurité JWT ---
SECRET_KEY=changez-moi-pour-production-ensa-kenitra-2025
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- API (pour le dashboard Streamlit) ---
# URL publique de l'API Railway après déploiement
# Exemple: https://ensa-bi-api.up.railway.app
API_URL=http://localhost:8000

# --- Identifiants par défaut (dashboard Streamlit) ---
# Utilisés par le dashboard pour s'authentifier automatiquement à l'API
API_USER=admin
API_PASS=admin123

# --- Environnement ---
ENVIRONMENT=development
LOG_LEVEL=INFO
